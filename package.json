{
  "name": "mal-tierlist-maker",
  "productName": "MAL Tierlist Maker",
  "description": "MyAnimeList profilinden sürükle-bırak tierlist oluşturucu",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:standalone": "vite build --config vite.standalone.config.js --outDir dist-standalone",
    "electron": "npm run build && electron .",
    "package": "npm run build && electron-packager . \"MAL Tierlist Maker\" --platform=win32 --arch=x64 --out=release --overwrite --ignore=node_modules --ignore=src --ignore=.vite",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.mal.tierlist.maker",
    "productName": "MAL Tierlist Maker",
    "asar": true,
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "axios": "^1.18.0",
    "html2canvas": "^1.4.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.12",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
